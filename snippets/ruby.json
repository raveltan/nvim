{
  "Rails Controller": {
    "prefix": "controller",
    "description": "Rails controller w/ before_action + actions",
    "body": [
      "class ${1:Name}Controller < ApplicationController",
      "\tbefore_action :set_${2:resource}, only: %i[show edit update destroy]",
      "",
      "\tdef index",
      "\t\t@${2}s = ${3:Model}.all",
      "\tend",
      "",
      "\tdef show; end",
      "",
      "\tdef new",
      "\t\t@${2} = ${3}.new",
      "\tend",
      "",
      "\tdef create",
      "\t\t@${2} = ${3}.new(${2}_params)",
      "\t\tif @${2}.save",
      "\t\t\tredirect_to @${2}, notice: '${3} was successfully created.'",
      "\t\telse",
      "\t\t\trender :new, status: :unprocessable_entity",
      "\t\tend",
      "\tend",
      "",
      "\tdef edit; end",
      "",
      "\tdef update",
      "\t\tif @${2}.update(${2}_params)",
      "\t\t\tredirect_to @${2}, notice: '${3} was successfully updated.'",
      "\t\telse",
      "\t\t\trender :edit, status: :unprocessable_entity",
      "\t\tend",
      "\tend",
      "",
      "\tdef destroy",
      "\t\t@${2}.destroy",
      "\t\tredirect_to ${2}s_url, notice: '${3} was successfully destroyed.'",
      "\tend",
      "",
      "\tprivate",
      "",
      "\tdef set_${2}",
      "\t\t@${2} = ${3}.find(params[:id])",
      "\tend",
      "",
      "\tdef ${2}_params",
      "\t\tparams.require(:${2}).permit(${4::name})",
      "\tend",
      "end"
    ]
  },
  "Rails API Controller": {
    "prefix": "apicontroller",
    "description": "API-only controller w/ JSON responses",
    "body": [
      "class Api::${1:V1}::${2:Name}Controller < ApplicationController",
      "\tbefore_action :set_${3:resource}, only: %i[show update destroy]",
      "",
      "\tdef index",
      "\t\trender json: ${4:Model}.all",
      "\tend",
      "",
      "\tdef show",
      "\t\trender json: @${3}",
      "\tend",
      "",
      "\tdef create",
      "\t\t@${3} = ${4}.new(${3}_params)",
      "\t\tif @${3}.save",
      "\t\t\trender json: @${3}, status: :created",
      "\t\telse",
      "\t\t\trender json: @${3}.errors, status: :unprocessable_entity",
      "\t\tend",
      "\tend",
      "",
      "\tdef update",
      "\t\tif @${3}.update(${3}_params)",
      "\t\t\trender json: @${3}",
      "\t\telse",
      "\t\t\trender json: @${3}.errors, status: :unprocessable_entity",
      "\t\tend",
      "\tend",
      "",
      "\tdef destroy",
      "\t\t@${3}.destroy",
      "\t\thead :no_content",
      "\tend",
      "",
      "\tprivate",
      "",
      "\tdef set_${3}",
      "\t\t@${3} = ${4}.find(params[:id])",
      "\tend",
      "",
      "\tdef ${3}_params",
      "\t\tparams.require(:${3}).permit($0)",
      "\tend",
      "end"
    ]
  },
